{
  "name": "pos-system-app",
  "productName": "نظام مثلث",
  "version": "1.1.2",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.pos.system",
    "publish": ["github"],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "appx",
          "arch": ["x64"]
        }
      ]
    },
    "appx": {
      "identityName": "Deltapos",
      "publisher": "CN=Deltapos",
      "publisherDisplayName": "Deltapos",
      "applicationId": "Deltapos",
      "displayName": "Deltapos",
      "languages": ["ar-SA", "en-US"]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  }
}
